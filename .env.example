# 聚合 API 根地址（不要末尾斜杠，不要带 /v1）
API_BASE_URL=https://api.apimart.ai

# 聚合平台密钥（勿提交真实密钥；复制本文件为 .env 后填写）
API_KEY=

# 本地默认 8888；Render 会自动注入 PORT，无需手动设置
# PORT=8888

# ---------- Render 部署 ----------
# 1. https://dashboard.render.com → New → Web Service → 连接 GitHub 仓库
# 2. Runtime: Node | Build: npm install | Start: npm start
# 3. Environment 添加 API_BASE_URL、API_KEY（与上面相同）
# 4. 部署完成后访问分配的 *.onrender.com 域名
